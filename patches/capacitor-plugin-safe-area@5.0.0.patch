+    /**
+     * Get only the display cutout insets (notch/camera cutout), excluding system bars
+     */
+    public JSObject getDisplayCutoutInsets() {
+        if (this.bridge == null || this.bridge.getActivity() == null) {
+            return this.result(0, 0, 0, 0);
+        }
+        View decor = this.bridge.getActivity().getWindow().getDecorView();
+        if (decor == null) {
+            return this.result(0, 0, 0, 0);
+        }
+        int top = 0, left = 0, right = 0, bottom = 0;
+        // Display cutouts are only available on Android P (API 28) and above
+        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.P) {
+            try {
+                WindowInsetsCompat insetsCompat = ViewCompat.getRootWindowInsets(decor);
+                if (insetsCompat != null) {
+                    DisplayCutoutCompat dc = insetsCompat.getDisplayCutout();
+                    if (dc != null) {
+                        top = dc.getSafeInsetTop();
+                        left = dc.getSafeInsetLeft();
+                        right = dc.getSafeInsetRight();
+                        bottom = dc.getSafeInsetBottom();
+                    }
+                }
+            } catch (Throwable t) {
+                Log.i(SafeAreaPlugin.class.toString(), "DisplayCutoutCompat failed, trying platform API: " + t);
+            }
+            // Fallback to platform API
+            if (top == 0 && left == 0 && right == 0 && bottom == 0) {
+                try {
+                    WindowInsets winInsets = decor.getRootWindowInsets();
+                    if (winInsets != null) {
+                        DisplayCutout displayCutout = winInsets.getDisplayCutout();
+                        if (displayCutout != null) {
+                            top = displayCutout.getSafeInsetTop();
+                            left = displayCutout.getSafeInsetLeft();
+                            right = displayCutout.getSafeInsetRight();
+                            bottom = displayCutout.getSafeInsetBottom();
+                        }
+                    }
+                } catch (Throwable t) {
+                    Log.i(SafeAreaPlugin.class.toString(), "Platform DisplayCutout failed: " + t);
+                }
+            }
+        }
+        return this.result(top, left, right, bottom);
+    }
+
